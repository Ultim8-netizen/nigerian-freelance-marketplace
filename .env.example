# ============================================================================
# F9 — Environment Variable Reference
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.
# ============================================================================

# GENERAL
NEXT_PUBLIC_APP_URL=https://f9.ng
NEXT_PUBLIC_APP_NAME=F9
NODE_ENV=development

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Monnify Payment Gateway ───────────────────────────────────────────────────
# Server-only — never expose these to the client bundle
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_WEBHOOK_SECRET=
MONNIFY_SOURCE_ACCOUNT_NUMBER=
# Defaults to https://api.monnify.com — override for sandbox: https://sandbox.monnify.com
MONNIFY_BASE_URL=https://api.monnify.com

# Client-safe — controls which Monnify environment is targeted
# Values: "test" | "live"
NEXT_PUBLIC_MONNIFY_ENV=test

# ── Cloudinary ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=marketplace_unsigned
CLOUDINARY_API_SECRET=

# ── Upstash Redis (rate limiting) ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://worthy-quagga-6583.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── Auth ──────────────────────────────────────────────────────────────────────
# Minimum 32 characters
JWT_SECRET=your-very-long-random-secret-key-here-minimum-32-chars
ENCRYPTION_KEY=generate_32_byte_hex_key_here

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW=60000  # 1 minute in ms
RATE_LIMIT_MAX=100       # requests per window

# ── Feature flags ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_LOCATION_DETECTION=true
NEXT_PUBLIC_ENABLE_UNIVERSITY_FILTER=true
NEXT_PUBLIC_ENABLE_ESCROW=true
NEXT_PUBLIC_MARKETPLACE_ENABLED=true

# ── Marketplace ───────────────────────────────────────────────────────────────
MARKETPLACE_MIN_PRODUCT_PRICE=100
MARKETPLACE_MAX_PRODUCT_PRICE=10000000
MARKETPLACE_MAX_IMAGES=8

# ── Gmail (support emails) ────────────────────────────────────────────────────
GMAIL_USER=eldergod263@gmail.com
GMAIL_APP_PASSWORD=your_app_specific_password_here

# ── Development only ──────────────────────────────────────────────────────────
# Set to 'true' to use test mode for payments
NEXT_PUBLIC_USE_TEST_PAYMENTS=true
# Set to 'true' to skip email verification in development
SKIP_EMAIL_VERIFICATION=false